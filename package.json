{
  "name": "yaqinhasan.com",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run gen:cv-json && npm run gen:blog",
    "build": "vite-ssg build",
    "serve": "npm run build && npx serve dist",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "vue-tsc --noEmit",
    "prettier": "prettier --check ./",
    "prettier:fix": "prettier --write ./",
    "lint": "eslint src/",
    "lint:fix": "eslint --fix src/",
    "setup:playwright": "playwright install chromium",
    "sync:github": "tsx --env-file=.env scripts/sync-github-projects.ts",
    "gen:blog": "tsx scripts/build-blog.ts && npm run prettier:fix",
    "gen:cv-schema": "tsx scripts/generate-cv-schema.ts",
    "gen:cv-json": "tsx scripts/generate-cv-json.ts",
    "render:cv": "npx tsx scripts/render-cv.ts",
    "validate:themes": "tsx scripts/validate-themes.ts",
    "validate:contrast": "tsx scripts/validate-contrast.ts",
    "audit:projects": "tsx scripts/audit-projects.ts"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@tailwindcss/typography": "^0.5.19",
    "@vueuse/core": "^14.2.1",
    "gray-matter": "^4.0.3",
    "marked": "^17.0.5",
    "shiki": "^4.0.2",
    "swiper": "^12.1.2",
    "vite-ssg": "^28.3.0",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3",
    "zod": "^4.3.6"
  },
  "overrides": {
    "minimatch": "^9.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@octokit/openapi-types": "^27.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.3.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.3.0",
    "happy-dom": "^20.7.0",
    "json-schema-to-zod": "^2.7.0",
    "playwright": "^1.58.2",
    "polished": "^4.3.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-plugin-static-copy": "^3.2.0",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5"
  }
}
